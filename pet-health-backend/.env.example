PORT=3000
GEMINI_API_URL=https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_IMAGE_BUCKET=pet-diagnosis-images

GEMINI_MODEL_CANDIDATES=gemini-2.5-flash,gemini-2.0-flash
AI_DEBUG_LOG_ENABLED=false
AI_DEBUG_LOG_INCLUDE_MEDIA_BASE64=false
LOG_ALL_REQUESTS=false
LOG_REQUEST_BODY=false
LOG_RESPONSE_BODY=false
# Analysis guardrails (short-term cost control)
ANALYSIS_IN_FLIGHT_TTL_SECONDS=300
ANALYSIS_COOLDOWN_SECONDS=90
ANALYSIS_RATE_LIMIT_HOURLY=10
ANALYSIS_RATE_LIMIT_DAILY=40

ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=your_email@gmail.com
ALERT_SMTP_PASS=your_app_password

ALERT_ERROR_FROM_EMAIL=your_email@gmail.com
ALERT_ERROR_TO_EMAIL=your_email@gmail.com
ALERT_MIN_INTERVAL_SECONDS=300

# Internal admin endpoint protection
ADMIN_INTERNAL_API_KEY=replace_with_long_random_secret