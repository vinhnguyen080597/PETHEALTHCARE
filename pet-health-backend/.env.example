PORT=3000
GEMINI_API_URL=https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_PRIVATE_MEDIA_BUCKET=pet-health-private-media
SUPABASE_PUBLIC_MEDIA_BUCKET=pet-feed-public-media
# Backward-compatible fallback only; prefer the split bucket vars above.
# SUPABASE_IMAGE_BUCKET=pet-health-private-media

# Lightweight signup identifiers. Non-email login names are mapped to internal Supabase emails.
AUTH_FREE_TEXT_DOMAIN=pethealth.local

GEMINI_MODEL_CANDIDATES=gemini-2.5-flash,gemini-2.0-flash
AI_DEBUG_LOG_ENABLED=false
AI_DEBUG_LOG_INCLUDE_MEDIA_BASE64=false
LOG_ALL_REQUESTS=false
LOG_REQUEST_BODY=false
LOG_RESPONSE_BODY=false
# Comma-separated browser origins allowed by CORS in production.
# Native mobile requests usually have no Origin header and are still accepted.
CORS_ORIGINS=https://your-frontend-preview.example.com
ALLOW_OPEN_CORS=false
# Analysis guardrails (short-term cost control)
ANALYSIS_IN_FLIGHT_TTL_SECONDS=300
ANALYSIS_COOLDOWN_SECONDS=90
ANALYSIS_RATE_LIMIT_HOURLY=10
ANALYSIS_RATE_LIMIT_DAILY=40

# AI unit economics / paid Gemini metering
AI_INITIAL_TRIAL_CREDITS=0
AI_TRIAL_CREDITS_HEALTH_ANALYSIS=1
AI_TRIAL_CREDITS_BREED_RECOGNITION=1
AI_FREE_MONTHLY_CREDITS=0
AI_DEFAULT_PLAN_TIER=free
AI_CREDITS_HEALTH_ANALYSIS=1
AI_CREDITS_BREED_RECOGNITION=1
AI_CREDITS_ANALYSIS_TRANSLATION=0.25
AI_ESTIMATE_INPUT_USD_PER_1M=0.25
AI_ESTIMATE_OUTPUT_USD_PER_1M=1.50
AI_GLOBAL_DAILY_BUDGET_USD=10
AI_GLOBAL_MONTHLY_BUDGET_USD=200
AI_FEATURE_DAILY_BUDGET_USD_HEALTH_ANALYSIS=6
AI_FEATURE_DAILY_BUDGET_USD_BREED_RECOGNITION=3
AI_FEATURE_DAILY_BUDGET_USD_ANALYSIS_TRANSLATION=1
AI_REWARDED_AD_CREDITS=1
AI_REWARDED_AD_DAILY_CAP=3
AI_MIN_IMAGE_BYTES=128
AI_MAX_VACCINE_TEXT_CHARS=500
AI_MAX_MEDICAL_HISTORY_CHARS=1500
AI_MAX_SYMPTOM_DESCRIPTION_CHARS=1200
AI_MAX_TRANSLATION_FIELD_CHARS=4000
# Vietnam beta defaults exposed by /api/v1/ai-credits/summary:
# initial trial = 2 credits (one health + one breed); monthly free quota = 0 credits;
# rewarded ad = 1 credit, max 3/day;
# starter pack = 5 credits / 19,000 VND; family pack = 20 credits / 59,000 VND;
# premium beta = 60 credits / 99,000 VND monthly.
BREED_RECOGNITION_IN_FLIGHT_TTL_SECONDS=300
BREED_RECOGNITION_COOLDOWN_SECONDS=120
BREED_RECOGNITION_RATE_LIMIT_HOURLY=8
BREED_RECOGNITION_RATE_LIMIT_DAILY=20

ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=your_email@gmail.com
ALERT_SMTP_PASS=your_app_password

ALERT_ERROR_FROM_EMAIL=your_email@gmail.com
ALERT_ERROR_TO_EMAIL=your_email@gmail.com
ALERT_MIN_INTERVAL_SECONDS=300

# Internal admin endpoint protection
ADMIN_INTERNAL_API_KEY=replace_with_long_random_secret
ALLOW_ADMIN_TEST_ALERT_EMAIL=false