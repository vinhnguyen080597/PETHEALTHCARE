EXPO_PUBLIC_API_ORIGIN=https://your-backend-host.onrender.com
# Optional overrides if the backend path layout changes:
# EXPO_PUBLIC_API_BASE_URL=https://your-backend-host.onrender.com/api/v1
# EXPO_PUBLIC_API_HEALTH_URL=https://your-backend-host.onrender.com/health

# OAuth client IDs for production builds, if enabled in the login UI:
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Do not set this in production app builds. Expo public env vars are bundled into the app.
EXPO_PUBLIC_ADMIN_INTERNAL_API_KEY=
