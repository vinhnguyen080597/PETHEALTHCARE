EXPO_PUBLIC_API_ORIGIN=https://your-backend-host.onrender.com
# Optional overrides if the backend path layout changes:
# EXPO_PUBLIC_API_BASE_URL=https://your-backend-host.onrender.com/api/v1
# EXPO_PUBLIC_API_HEALTH_URL=https://your-backend-host.onrender.com/health

# OAuth client IDs for production builds, if enabled in the login UI:
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Public release links. These must point to live pages before App Store submission.
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://vinhnguyen080597.github.io/PETHEALTHCARE/privacy-policy/
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://vinhnguyen080597.github.io/PETHEALTHCARE/terms-of-service/
EXPO_PUBLIC_SUPPORT_URL=https://vinhnguyen080597.github.io/PETHEALTHCARE/support/

# AdMob — production EAS builds (dev uses Google test IDs):
# EXPO_PUBLIC_ADMOB_APP_IOS=ca-app-pub-xxxxxxxx~yyyyyyyy
# EXPO_PUBLIC_ADMOB_APP_ANDROID=ca-app-pub-xxxxxxxx~yyyyyyyy
# EXPO_PUBLIC_ADMOB_REWARDED_IOS=ca-app-pub-xxxxxxxx/zzzzzzzz
# EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=ca-app-pub-xxxxxxxx/zzzzzzzz
