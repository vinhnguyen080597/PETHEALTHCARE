{
  "name": "pet-health-frontend",
  "version": "1.1.2",
  "main": "index.ts",
  "scripts": {
    "start": "cross-env EXPO_PUBLIC_EXPO_GO_COMPAT=1 npx expo start --go --lan --port 8081",
    "dev": "cross-env EXPO_PUBLIC_EXPO_GO_COMPAT=1 npx expo start --go --tunnel --port 8081 -c",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "node --test --experimental-strip-types \"test/**/*.test.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --project=chromium --headed --workers=1",
    "test:e2e:slow": "cross-env E2E_SLOW_MO_MS=1000 E2E_EXPECT_DELAY_MS=1000 E2E_API_DELAY_MS=3000 playwright test --project=chromium --headed --workers=1",
    "test:e2e:debug": "cross-env E2E_SLOW_MO_MS=1000 E2E_EXPECT_DELAY_MS=1000 E2E_API_DELAY_MS=3000 playwright test --project=chromium --debug",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "release:verify:public-links": "node scripts/verify-public-links.mjs",
    "release:verify:backend": "node scripts/verify-production-backend.mjs",
    "release:verify:native-autolinking": "node scripts/verify-native-autolinking.mjs",
    "release:smoke:native": "node scripts/release-native-smoke.mjs",
    "release:check": "yarn typecheck && yarn test && npx expo-doctor && yarn release:verify:public-links && yarn release:verify:backend",
    "build:ios:production": "eas build --platform ios --profile production",
    "build:ios:production:submit": "eas build --platform ios --profile production --auto-submit",
    "build:android:production": "eas build --platform android --profile production",
    "submit:ios:production": "eas submit --platform ios --profile production --latest"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-build-properties": "~1.0.10",
    "expo-crypto": "~15.0.9",
    "expo-font": "~14.0.12",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-localization": "~17.0.9",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "i18next": "^26.0.8",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "exclude": [
        "react-native-google-mobile-ads",
        "react-native-iap",
        "react-native-nitro-modules"
      ]
    }
  }
}
